rules_version = '2';

// ══════════════════════════════════════════════════════════════════
//  THE STEPPER — Firestore 보안 규칙 (전체본)
//  2026-07-21 콘솔에서 직접 받아온 실제 배포본과 동기화함.
//  (repo 루트의 firestore.rules 가 firebase.json 이 참조하는 실제
//   배포 소스이며, 이 파일은 그것과 동일하게 유지하는 문서용 사본이다)
// ══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {
    match /visitors/{doc=**} {
      allow read, write: if true;
    }
    match /stats/{doc=**} {
      allow read, write: if true;
    }
    match /movement_data/{doc=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /schedules/{doc=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /locations/{doc=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /inquiries/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || request.auth.token.email == 'tkdboykms0007@gmail.com');
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }
    match /aiUsage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
      allow write: if false;
    }
    match /ai_coaching/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.email == 'tkdboykms0007@gmail.com'
      );
      allow update: if request.auth != null && (
        request.auth.token.email == 'tkdboykms0007@gmail.com' ||
        (resource.data.userId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewed']))
      );
    }
    match /expertUsage/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /coaching_knowledge/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /ai_interview/{doc=**} {
      allow read: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /voice_drafts/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'tkdboykms0007@gmail.com';
    }
    match /user_messages/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewed']);
      allow create, delete: if false;
    }
  }
}
