rules_version = '2';

// ══════════════════════════════════════════════════════════════════
//  THE STEPPER — Firebase Storage 보안 규칙 (전체본)
//
//  ⚠ 콘솔에 통째로 교체하기 전에 반드시 확인하세요.
//     이 파일은 저장소 코드에서 실제로 사용하는 경로를 근거로 작성했습니다.
//     콘솔의 현재 규칙을 직접 읽을 수는 없으므로, 여기에 없는 경로를
//     쓰고 계셨다면 그 부분이 빠질 수 있습니다.
//     교체 전 콘솔 규칙과 눈으로 비교해 주세요.
//
//  코드에서 확인된 사용 경로
//    gallery/            index.html 이 listAll 로 목록 조회 (공개 읽기 필요)
//    assets/             og_image.png 등 정적 이미지 (공개 읽기)
//    sos_videos/{uid}/   motion-legacy.html 업로드 · 서버가 답변 후 삭제
//    movement_landmarks/ [신규] 동작분석 관절 좌표 JSON (관리자 전용)
//    movement_videos/    [신규] 동작분석 원본 영상 (관리자 전용)
// ══════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── 공통 헬퍼 ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'tkdboykms0007@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ── 갤러리 (홈페이지 공개 노출) ────────────────────────────
    // 읽기: 누구나 / 쓰기: 관리자만
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 정적 에셋 (og 이미지 등) ───────────────────────────────
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── SOS 영상 ───────────────────────────────────────────────
    // 본인 폴더에만 업로드 가능. 읽기/삭제는 관리자(및 본인).
    // 서버(Admin SDK)는 규칙을 우회하므로 답변 후 자동 삭제에 영향 없음.
    match /sos_videos/{userId}/{fileName} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isVerified()
                    && request.auth.uid == userId
                    && request.resource.size < 200 * 1024 * 1024
                    && request.resource.contentType.matches('video/.*');
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // ── [신규] 동작분석 관절 좌표 JSON ─────────────────────────
    // movement_landmarks/{docId}.json      (무압축)
    // movement_landmarks/{docId}.json.gz   (gzip 압축)
    // 학습용 원천 데이터이므로 관리자만 접근한다.
    match /movement_landmarks/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin()
                   && request.resource.size < 50 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // ── [신규] 동작분석 원본 영상 ──────────────────────────────
    // movement_videos/{docId}.mp4 / .mov / .webm ...
    // 나중에 다른 분석 방식으로 재처리해야 하므로 자동 삭제하지 않는다.
    match /movement_videos/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin()
                   && request.resource.size < 500 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // ── 그 외 모든 경로: 기본 차단 ─────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
