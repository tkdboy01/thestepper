{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/schedule",
      "dest": "/schedule.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/locations",
      "dest": "/locations.html"
    },
    {
      "src": "/staff",
      "dest": "/staff.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
